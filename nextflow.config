workDir = "/tmp/${System.getProperty('user.name')}_nxf"

params {
    samples             = "samples.tsv"
    data_dir            = "data"
    outdir              = "results"
    genome              = "references/Homo_sapiens.GRCh37.75.dna.primary_assembly.fa"
    gtf                 = "references/Homo_sapiens.GRCh37.75.gtf"
    hisat2_index        = "references/grch37/genome"
    adapters            = "${System.getenv('CONDA_PREFIX')}/share/trimmomatic-0.40-0/adapters/TruSeq3-PE-2.fa"
    trimmed_read_length = 99
    fdr_threshold       = 0.1
    splicing_env        = "splicing-env"
}

process {
    cpus   = 2
    memory = '8 GB'

    withName: 'TRIMMOMATIC' {
        cpus   = 4        
        memory = '16 GB'
    }
    withName: 'HISAT2_ALIGN' {
        cpus     = 16     
        memory   = '32 GB'
        maxForks = 2      
    }
    withName: 'DEXSEQ_COUNT' {
        cpus   = 1
        memory = '32 GB'  
    }
    withName: 'DEXSEQ_ANALYSIS' {
        cpus   = 1
        memory = '64 GB'  
    }
    withName: 'RMATS' {
        cpus     = 8      
        memory   = '32 GB'
        maxForks = 2      
    }
}
